{
  "name": "defendts",
  "version": "0.1.1",
  "description": "TypeScript SDK for Defend guardrail API.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Adxzer/defend",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Adxzer/defend.git"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3"
  }
}
