DEFEND_API_HOST=0.0.0.0
DEFEND_API_PORT=8000

# Models used for the pipeline
INTENT_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
PERPLEXITY_MODEL_ID=openai-community/gpt2
DEFEND_MODEL_ID=Adaxer/defend

INTENT_FASTPASS_THRESHOLD=0.85
REGEX_BLOCK_THRESHOLD=0.9
REGEX_FLAG_THRESHOLD=0.6
PERPLEXITY_BLOCK_THRESHOLD=80.0
SESSION_BLOCK_THRESHOLD=0.9

# Required when provider or guards.input/guards.output use claude.
# Do not commit real keys.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required when provider or guards.input/guards.output use openai.
# Do not commit real keys.
# OPENAI_API_KEY=your_openai_api_key_here

