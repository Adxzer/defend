# Example environment configuration for Defend API
# Copy this file to .env and fill in real values for local development.
DEFEND_ENV=test

DEFEND_API_HOST=0.0.0.0
DEFEND_API_PORT=8000

# Models used for the pipeline
INTENT_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
DEFEND_MODEL_ID=Adaxer/defend

# Intent thresholds
INTENT_FASTPASS_THRESHOLD=0.85
REGEX_BLOCK_THRESHOLD=0.9
REGEX_FLAG_THRESHOLD=0.6

# Defend model runtime caps
DEFEND_MAX_INPUT_TOKENS=1024
DEFEND_INJECTION_THRESHOLD=0.5

# Semantic provider input caps
ANTHROPIC_MAX_INPUT_TOKENS=2048
OPENAI_MAX_INPUT_TOKENS=2048

# Session settings
SESSION_TTL_SECONDS=1800
SESSION_BLOCK_THRESHOLD=3

# Required when provider or guards.input/guards.output use claude.
# Do not commit real keys.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required when provider or guards.input/guards.output use openai.
# Do not commit real keys.
# OPENAI_API_KEY=your_openai_api_key_here
