DEFEND_API_HOST=0.0.0.0
DEFEND_API_PORT=8000

# Redis connection used for L5 session accumulation and guard sessions.
REDIS_URL=redis://redis:6379/0

# Intent (L2) – sentence-transformers
# Override to change the fast-pass intent model.
INTENT_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2

# Perplexity (L4) – GPT-2 from Hugging Face
# https://huggingface.co/openai-community/gpt2
PERPLEXITY_MODEL_ID=openai-community/gpt2

# Defend (L6) – Adaxer/defend is the default classifier
# https://huggingface.co/Adaxer/defend
DEFEND_MODEL_ID=Adaxer/defend

INTENT_FASTPASS_THRESHOLD=0.85
REGEX_BLOCK_THRESHOLD=0.9
REGEX_FLAG_THRESHOLD=0.6
PERPLEXITY_BLOCK_THRESHOLD=80.0
SESSION_BLOCK_THRESHOLD=0.9

# Optional Hugging Face token for private models / higher rate limits.
# HUGGINGFACE_HUB_TOKEN=your_token_here

# LLM providers (Claude / OpenAI).
# Required when provider or guards.input/guards.output use claude.
# Do not commit real keys.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required when provider or guards.input/guards.output use openai.
# Do not commit real keys.
# OPENAI_API_KEY=your_openai_api_key_here

